DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobcloud01?schema=public"
AUTH_SECRET="replace-this-with-a-long-random-string"
AUTH_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"
EMAIL_FROM="noreply@jobcloud01.local"
EMAIL_PROVIDER="console"
# Amazon Bedrock — powers ALL LLM features (onboarding assistant, sourcing,
# signals, CV extraction, guidance, interview).
# AWS_BEARER_TOKEN_BEDROCK is a Bedrock API key (Bearer token) generated in the
# Amazon Bedrock console. Keep it secret; never commit the real value.
AWS_BEARER_TOKEN_BEDROCK="replace-with-your-bedrock-api-key"
BEDROCK_REGION="eu-west-1"
BEDROCK_MODEL_ID="eu.anthropic.claude-sonnet-5"
