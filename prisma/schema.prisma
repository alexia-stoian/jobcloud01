generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActorType {
  USER
  ASSISTANT
  SYSTEM
}

enum ProfileMutationSource {
  CHAT
  AUTH_FLOW
  SYSTEM_REVERT
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          UserRole  @default(USER)

  accounts         Account[]
  sessions         Session[]
  profile          CandidateProfile?
  onboardingSession OnboardingSession?
  verifyTokens     VerificationToken[] @relation("verify_token_user")
  resetTokens      PasswordResetToken[]
  authAuditEvent   AuthAuditEvent[]
  interviewSessions InterviewSession[]
  completedResources CompletedResource[]
  storedArtifacts  StoredArtifact[]
  candidateSignalState CandidateSignalState?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  tokenHash  String   @unique
  expires    DateTime
  userId     String?

  user User? @relation("verify_token_user", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([identifier, tokenHash])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CandidateProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  locale                String   @default("en")
  fullName              String?
  currentJobSituation   String?
  employmentObjective   String?
  primaryRole           String?
  preferredLocation     String?
  targetRoles           String?
  targetSeniority       String?
  targetIndustries      String?
  preferredWorkModel    String?
  contractPreference    String?
  workRate              String?
  workPermitStatus      String?
  salaryExpectation     String?
  workAuthorization     String?
  visaSponsorship       String?
  relocationWillingness String?
  commuteRadius         String?
  editorDraft           Json     @default("{}")
  assistantState        Json     @default("{}")
  roleSuggestionsUsed   Boolean  @default(false)
  isMinimallyComplete   Boolean  @default(false)
  missingCriticalFields Json     @default("[]")
  lastCompletionCheckAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  qualifications ProfileQualification[]
  historyEvents  ProfileHistoryEvent[]
  onboardingSession OnboardingSession?
}

model ProfileQualification {
  id          String   @id @default(cuid())
  profileId   String
  category    String
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model ProfileHistoryEvent {
  id              String                @id @default(cuid())
  profileId       String
  userId          String
  actorType       ActorType
  source          ProfileMutationSource
  changeSet       Json
  confirmationRef String?
  createdAt       DateTime              @default(now())

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
}

model OnboardingSession {
  id                    String   @id @default(cuid())
  userId                String   @unique
  profileId             String?  @unique
  locale                String   @default("en")
  currentStep           String   @default("cv_upload")
  targetRole            String?
  cvFileName            String?
  cvMimeType            String?
  cvExtractedFacts      Json     @default("{}")
  cvUncertainFacts      Json     @default("{}")
  conversationHistory   Json     @default("[]")
  pendingQuestions      Json     @default("[]")
  skippedQuestionIds    Json     @default("[]")
  confirmedQuestionIds  Json     @default("[]")
  lastInteractedAt      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile CandidateProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId, currentStep])
}

model AuthAuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
}

model InterviewSession {
  id              String   @id @default(cuid())
  userId          String
  interviewType   String   // "behavioral" | "technical" | "case-study" | "cultural-fit"
  targetRole      String?
  locale          String   @default("en")
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  overallScore    Int?     // 0-100
  strengths       Json     @default("[]")
  improvements    Json     @default("[]")
  recommendations Json     @default("[]")
  userRating      Int?     // 1-5 user's rating
  userFeedback    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions InterviewQuestion[]

  @@index([userId, createdAt])
  @@index([userId, interviewType])
}

model InterviewQuestion {
  id          String   @id @default(cuid())
  sessionId   String
  questionNum Int      // 1-7 for question order
  question    String
  userAnswer  String?
  feedback    String?
  score       Int?     // 0-100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@unique([sessionId, questionNum])
}

model CompletedResource {
  id          String   @id @default(cuid())
  userId      String
  resourceId  String   // References resource from SKILL_RESOURCES database
  skill       String   // Skill tag (e.g., "Python", "SQL")
  resourceTitle String
  completedAt DateTime @default(now())
  rating      Int?     // 1-5 user rating
  feedback    String?
  timeSpent   Int?     // minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId, skill])
  @@index([userId, completedAt])
}

// Artifact storage for retrieval and modification
model StoredArtifact {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Artifact type: cover_letter | job_posting | interview_qa
  type              String
  
  // Full artifact content (verbatim storage)
  content           String    @db.Text
  
  // Metadata for retrieval (JSON: company, jobTitle, question, sessionId, etc.)
  metadata          Json      @default("{}")
  
  // Versioning
  version           Int       @default(1)
  parentArtifactId  String?   // Reference to original if this is an edit
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([userId, type, createdAt])
}

// Invisible recruiter-signals inference state — one row per user holding all 11
// signals as a structured JSON array (see SignalRecord in signal-definitions.ts).
model CandidateSignalState {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Array of 11 SignalRecord objects (key, name, category, inferredValue,
  // confidence 0-100, evidence[], contradictionFlags[], lastUpdated, sessionId,
  // updateHistory[]). The DAL owns the shape.
  signals     Json     @default("[]")

  // Cross-session bookkeeping
  lastSessionId String?
  inputCount    Int      @default(0)   // how many user inputs have been processed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Phase 11 — Sourcing skill-gap questions.
//
// Additive relational store for a recruiter's sourcing run and the personalized
// close-the-gap Q&A queued per high-match candidate. Mirrors the
// InterviewSession -> InterviewQuestion shape (cuid ids, camelCase fields, Json
// arrays, cascade deletes, @@index). Candidate/recruiter ids are stored as plain
// String columns (like CandidateSignalState) — no relations onto existing models.
//
// SERVER-ONLY correctness data lives here: SourcingQuestion.options carry
// isCorrect/isOpen flags and SourcingQuestion.gapLabel / SourcingAnswer.satisfiedNeed
// are silent judgments that MUST be stripped before anything reaches a candidate.
// ---------------------------------------------------------------------------

// One recruiter sourcing run. Sourcing is stateless per JSON upload, so we mint a
// run id here and snapshot the sanitized recruiter needs for later card display.
model SourcingSession {
  id              String   @id @default(cuid())
  recruiterUserId String                        // the admin who ran the sourcing
  needsSnapshot   Json     @default("{}")        // RecruiterNeeds (sanitized) — SERVER-ONLY
  roleLabel       String?                        // e.g. needs.role, for card display
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidates SourcingCandidate[]

  @@index([recruiterUserId, createdAt])
}

// One queued question-set for one candidate. "One active set per candidate" is
// app-enforced (no DB unique) so history is preserved: Plan 2 retires any existing
// non-completed set before queueing; read-back reflects the MOST RECENT set by
// createdAt regardless of status.
model SourcingCandidate {
  id              String   @id @default(cuid())
  sessionId       String
  candidateUserId String                        // the candidate this question-set is for
  fitBefore       Int                            // displayed fitPercent at generation time
  fitAfter        Int?                           // set after re-score; null until answered
  status          String   @default("pending")  // pending | delivering | completed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session   SourcingSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questions SourcingQuestion[]

  @@index([candidateUserId, status])
  @@index([sessionId])
}

// One generated gap question. options is [{ value, label, isCorrect, isOpen }];
// isCorrect/isOpen and gapLabel are SERVER-ONLY and must be stripped before delivery.
model SourcingQuestion {
  id          String   @id @default(cuid())
  candidateId String
  orderIndex  Int                               // 0..4 delivery order
  gapLabel    String                            // checklist gap this targets — SERVER-ONLY
  prompt      String   @db.Text
  options     Json     @default("[]")           // [{ value, label, isCorrect, isOpen }]
  allowCustom Boolean  @default(true)            // the open "write your own answer" path
  createdAt   DateTime @default(now())

  candidate SourcingCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  answer    SourcingAnswer?

  @@unique([candidateId, orderIndex])
  @@index([candidateId, orderIndex])
}

// One candidate answer. satisfiedNeed is the silent LLM judgment — NEVER returned
// to the candidate.
model SourcingAnswer {
  id            String   @id @default(cuid())
  questionId    String   @unique
  chosenValue   String?                         // option value chosen, or null for open
  freeText      String?  @db.Text               // the open answer, when allowCustom used
  satisfiedNeed Boolean  @default(false)        // silent judgment — SERVER-ONLY
  createdAt     DateTime @default(now())

  question SourcingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}
